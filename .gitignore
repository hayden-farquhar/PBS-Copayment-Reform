# Data files (too large for git; regenerated by scripts)
data/raw/
data/processed/*.csv
data/spatial/

# Keep directory structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/spatial/.gitkeep

# Python
.venv/
__pycache__/
*.pyc

# R
.Rproj.user/
.Rhistory
.RData
.Rdata
*.Rproj

# OS
.DS_Store
Thumbs.db

# Outputs (regenerated by scripts)
outputs/figures/*.png
outputs/figures/*.pdf
outputs/tables/*.csv
outputs/tables/*.tex
outputs/maps/*.png
outputs/maps/*.pdf
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep
!outputs/maps/.gitkeep
